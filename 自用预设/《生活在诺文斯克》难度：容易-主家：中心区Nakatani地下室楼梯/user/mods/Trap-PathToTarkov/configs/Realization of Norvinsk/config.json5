{
  // 当配置文件创建时（或首次安装PTT时）的默认脱战位置
  initial_offraid_position: 'PlayerHideout',

  // 玩家死亡时的脱战位置（仅在 `reset_offraid_position_on_player_die` 为 true 时生效）
  // 你可以在这里放置多个脱战位置，死亡时会随机选择一个
  respawn_at: ['PlayerHideout'],

  // 启用此选项后，将根据定义的路径自动创建传送点
  enable_automatic_transits_creation: false,

  // 官方不支持原版传送点，但你仍然可以在这里启用它们
  enable_all_vanilla_transits: true,

  // 查看 `Examples/OverrideByProfiles` 配置文件以获取完整的使用示例
  override_by_profiles: {},

  debug_exfiltrations_tooltips_locale: 'en',

